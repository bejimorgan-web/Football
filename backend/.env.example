MODE=production
API_BASE_URL=https://your-backend-domain.example.com
CORS_ALLOW_ORIGINS=*

# Admin access
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# IPTV provider
XTREAM_SERVER_URL=
XTREAM_USERNAME=
XTREAM_PASSWORD=
M3U_PLAYLIST_URL=
CACHE_TTL_SECONDS=300

# Optional notifications/backups
BACKUP_SCHEDULE=0 3 * * *
BACKUP_PATH=
BACKUP_RETENTION=7
SUBSCRIPTION_REMINDER_SCHEDULE=0 9 * * *
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
PLATFORM_BASE_URL=
DESKTOP_DOWNLOAD_URL=
